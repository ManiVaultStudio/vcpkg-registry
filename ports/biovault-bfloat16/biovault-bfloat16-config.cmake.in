include(CMakeFindDependencyMacro)

if(NOT TARGET biovault-bfloat16::biovault-bfloat16)
    add_library(biovault-bfloat16::biovault-bfloat16 INTERFACE IMPORTED)
    set_target_properties(biovault-bfloat16::biovault-bfloat16 PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${CMAKE_CURRENT_LIST_DIR}/../../include"
    )
endif()