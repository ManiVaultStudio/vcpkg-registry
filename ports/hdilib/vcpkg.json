{
  "name": "hdilib",
  "version": "2.0.1",
  "description": "A C++ library for high-dimensional embeddings implementing tSNE and HSNE.",
  "dependencies": [
    "flann",
    "fmt",
    {
      "name": "glslang",
      "host": true,
      "features": [
        "tools"
      ]
    },
    {
      "name": "shaderc",
      "host": true
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    "kompute"
  ],
  "features": {
    "kompute": {
      "description": "Enable Vulkan/Kompute support",
      "dependencies": [
        "kompute"
      ]
    }
  },
  "overrides": [
    {
      "name": "kompute",
      "version": "0.10.0-a#3"
    }
  ]
}
